# Copy to a local shell/env file and fill in the real values.
# Do not commit Apple credentials or private keys.

# Code signing. Find this with: security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Company Name (TEAMID)"
APPLE_TEAM_ID="TEAMID"

# Notarization, option A: App Store Connect API key.
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY="ABC123DEFG"
APPLE_API_KEY_PATH="/Users/you/.appstoreconnect/private_keys/AuthKey_ABC123DEFG.p8"

# Notarization, option B: Apple ID + app-specific password.
# APPLE_ID="you@example.com"
# APPLE_PASSWORD="@keychain:AC_PASSWORD"

# Tauri updater artifact signing. This must match plugins.updater.pubkey.
TAURI_SIGNING_PRIVATE_KEY_PATH="/Users/you/.tauri/simpleos-updater.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""
