{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "app": {
    "windows": [
      {
        "title": "SimplEOS",
        "label": "main",
        "width": 1160,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 20 }
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"]
  }
}
