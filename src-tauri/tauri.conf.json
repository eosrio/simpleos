{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SimplEOS",
  "version": "2.0.0-alpha.0",
  "identifier": "io.eosrio.simpleos",
  "build": {
    "frontendDist": "../dist/simpleos/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "bun run start",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "SimplEOS",
        "label": "main",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 14, "y": 14 }
      }
    ],
    "security": {}

  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Antelope Desktop Wallet",
    "longDescription": "SimplEOS is a secure desktop wallet for Antelope-based blockchains including Vaulta (EOS), WAX, Telos, Ultra, FIO, Libre, and XPR.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["esr"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4NkJGMUVBRjk1MTZFODkKUldTSmJsSDU2dkZyV0pOMzJ4S1Z2NWxiSzdETHNTNWx4NFY1Nmh1WE9nTFF0NnFhRHRkNTYxSVgK",
      "endpoints": [
        "https://github.com/eosrio/simpleos/releases/latest/download/latest.json"
      ]
    }
  }
}
