{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "version": "2.0.0",
  "build": {
    "beforeBuildCommand": "bun run build:appstore"
  },
  "app": {
    "security": {
      "capabilities": [
        {
          "identifier": "appstore-local-main",
          "description": "Main SimplEOS window permissions for the locally testable sandboxed App Store build.",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "store:default",
            "window-state:default",
            "core:window:allow-start-dragging",
            "core:window:allow-start-resize-dragging",
            "core:window:allow-minimize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-is-maximized",
            "core:window:allow-close",
            "core:window:allow-set-focus",
            "deep-link:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "targets": ["app"],
    "createUpdaterArtifacts": false,
    "macOS": {
      "entitlements": "entitlements.appstore-local.plist"
    }
  }
}
