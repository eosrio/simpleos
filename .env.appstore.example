# Copy to a local shell/env file and fill in the real values.
# Do not commit certificates, API keys, or provisioning profiles.

APPLE_TEAM_ID="FS7QM58848"
DEVELOPER_DIR="/Applications/Xcode.app/Contents/Developer"

# Mac App Store signing certificates. The packaging script auto-detects these
# when possible. Find them with:
# security find-identity -v -p codesigning
# security find-identity -v -p basic
APPSTORE_APP_SIGNING_IDENTITY="3rd Party Mac Developer Application: Company Name (FS7QM58848)"
APPSTORE_INSTALLER_SIGNING_IDENTITY="3rd Party Mac Developer Installer: Company Name (FS7QM58848)"

# App Store Connect provisioning profile for io.eosrio.simpleos.
APPSTORE_PROVISIONING_PROFILE="/Users/you/Downloads/SimplEOS_Mac_App_Store.provisionprofile"

# Optional App Store Connect API credentials for command-line upload.
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY="ABC123DEFG"
APPLE_API_KEY_PATH="/Users/you/.appstoreconnect/private_keys/AuthKey_ABC123DEFG.p8"

# Optional when your Apple account has access to multiple providers.
# Xcode 26 altool can validate/upload with API keys, but --list-providers
# requires Apple ID authentication if you need to discover this value.
# APPLE_PROVIDER_PUBLIC_ID="12345678-1234-1234-1234-123456789012"

# Optional alternative for validation/upload.
# APPLE_ID="you@example.com"
# APPLE_PASSWORD="@keychain:AC_PASSWORD"
